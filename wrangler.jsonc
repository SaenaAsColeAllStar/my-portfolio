{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my-portfolio",
  "compatibility_date": "2026-06-26",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "my-portfolio"
    }
  ]
}
